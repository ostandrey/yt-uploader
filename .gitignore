# Environment variables
.env
*.env

# Credentials and tokens
credentials/
tokens/
*.json
# But allow config JSON files
!config/*.json

# Logs
logs/
*.log

# Generated content
storage/*/
storage/*/*/
storage/*/*/*/
# But keep directory structure
!storage/
!storage/*/
!storage/*/*/
# Ignore all media files
*.mp4
*.jpg
*.png
*.wav
*.mp3
# But allow .gitkeep files to maintain directory structure
!**/.gitkeep

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual environments
venv/
env/
ENV/

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Temporary files
temp-audio.m4a
*.tmp
*.temp

# Test outputs
test_video.mp4
test_audio.mp3

# Additional security
*.key
*.pem
*.p12
*.pfx

# Database files
*.db
*.sqlite
*.sqlite3

# Backup files
*.bak
*.backup
*~

# Windows specific
desktop.ini
$RECYCLE.BIN/

# macOS specific
.AppleDouble
.LSOverride
